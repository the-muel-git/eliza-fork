{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["tsconfig.json"],
    "tasks": {
        "build": {
            "outputs": ["dist/**"],
            "dependsOn": ["^build"],
            "env": ["NODE_OPTIONS"]
        },
        "@elizaos/core#build": {
            "outputs": ["dist/**"],
            "env": ["NODE_OPTIONS"]
        },
        "@elizaos/adapter-redis#build": {
            "outputs": ["dist/**"],
            "dependsOn": ["@elizaos/core#build"],
            "env": ["NODE_OPTIONS"]
        },
        "@elizaos/client-discord#build": {
            "outputs": ["dist/**"],
            "dependsOn": ["@elizaos/core#build"],
            "env": ["NODE_OPTIONS"]
        },
        "@elizaos/client-telegram#build": {
            "outputs": ["dist/**"],
            "dependsOn": ["@elizaos/core#build"],
            "env": ["NODE_OPTIONS"]
        }
    }
}
